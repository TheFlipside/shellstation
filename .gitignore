# ============================================================
# ShellStation .gitignore
# Tauri 2.x (Rust backend) + React/TypeScript/Vite frontend
# ============================================================

# ------------------------------------------------------------
# Rust / Cargo
# ------------------------------------------------------------
src-tauri/target/
**/*.rs.bk

# ------------------------------------------------------------
# Node.js / npm
# ------------------------------------------------------------
node_modules/
npm-debug.log*

# ------------------------------------------------------------
# Vite
# ------------------------------------------------------------
dist/

# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Tauri
# ------------------------------------------------------------
# Bundle output (installers, AppImage, .deb, .dmg, .msi)
src-tauri/target/
src-tauri/gen/
# Tauri generates icons during build
src-tauri/icons/generated/

# ------------------------------------------------------------
# SQLite
# ------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm

# ------------------------------------------------------------
# sqlx offline query cache
# Keep .sqlx/ tracked so CI can build without a live database.
# This entry is commented out intentionally.
# ------------------------------------------------------------
# .sqlx/

# ------------------------------------------------------------
# Environment and secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
# VS Code (keep settings, ignore local history and extensions)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# ------------------------------------------------------------
# Testing / Coverage
# ------------------------------------------------------------
coverage/
lcov.info
tarpaulin-report.html

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.bak
*.tmp
*.orig