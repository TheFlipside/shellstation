# Claude
.claude/** linguist-vendored

# Force LF line endings for SQL migrations so that sqlx checksums
# are consistent across Linux, macOS, and Windows checkouts.
src-tauri/migrations/*.sql text eol=lf

# Force LF for shell scripts so they work inside Docker containers
# when checked out on Windows (prevents #!/bin/sh\r errors).
ssh-testlab/scripts/*.sh text eol=lf
